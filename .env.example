# ============================================================
# CyberGuard Pro — Root Environment Variables
# Copy this to .env and fill in your AWS RDS details
# NEVER commit .env to version control
# ============================================================

# ── AWS RDS PostgreSQL ────────────────────────────────────
DB_HOST=your-db-instance.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=cyberguard
DB_USER=cyberguard_admin
DB_PASSWORD=YourStrongPasswordHere!
DB_SSL=true

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# ── Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
